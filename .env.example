# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DISCORD_WEBHOOK_URL: The URL from your Discord channel settings.
DISCORD_WEBHOOK_URL=""
# EMAIL_USER: The email address to send from (e.g., your Gmail).
# EMAIL_PASS: The App Password for the email account.
EMAIL_USER="affanayyan23@gmail.com"
EMAIL_PASS=""
